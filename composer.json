{
    "name": "monterhealth/api-filter-bundle",
    "description": "Rest Api filter and order bundle",
    "type": "symfony-bundle",
    "license": "MIT",
    "authors": [
        {
            "name": "Niels Geerts",
            "email": "nielsgeerts@monterhealth.nl"
        }
    ],
    "require": {
        "php": "^8.0",
        "doctrine/orm": "*"
    },
    "require-dev": {
        "doctrine/doctrine-bundle": "^2.12",
        "symfony/browser-kit": "^6.4",
        "symfony/dom-crawler": "^6.4",
        "symfony/framework-bundle": "^6.4",
        "symfony/phpunit-bridge": "^6.4"
    },
    "autoload": {
        "psr-4": {
            "MonterHealth\\ApiFilterBundle\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "MonterHealth\\ApiFilterBundle\\Tests\\": "tests/"
        }
    }
}
